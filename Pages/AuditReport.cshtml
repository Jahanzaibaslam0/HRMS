@page
@model HRMS.Pages.AuditReportModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HRMS - @Model.PageTitle</title>
    <link rel="stylesheet" href="/css/style.css?v=5" />
    <style>
        .audit-filters .form-grid { grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); }
        .audit-meta { font-size: .78rem; color: var(--text-muted); }
        .audit-details {
            max-width: 280px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            font-size: .75rem;
            color: #475569;
        }
        .action-pill {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 999px;
            font-size: .72rem;
            font-weight: 700;
            text-transform: uppercase;
        }
        .action-create { background: #dcfce7; color: #166534; }
        .action-update { background: #dbeafe; color: #1d4ed8; }
        .action-delete { background: #fee2e2; color: #b91c1c; }
        .action-login, .action-logout { background: #f3e8ff; color: #6b21a8; }
        .action-loginfailed { background: #fef3c7; color: #92400e; }
        .pager { display: flex; gap: .5rem; align-items: center; justify-content: flex-end; margin-top: 1rem; }
    </style>
</head>
<body>
    @await Html.PartialAsync("_AppHeader", Model.PageTitle)

    <main class="container">
        <div class="card">
            <div class="card-header"><h2>Search Audit Logs</h2></div>
            <div class="card-body audit-filters">
                <form method="get">
                    <div class="form-grid">
                        <div class="form-group">
                            <label>From Date</label>
                            <input type="date" name="dateFrom" class="form-control" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="form-group">
                            <label>To Date</label>
                            <input type="date" name="dateTo" class="form-control" value="@Model.DateTo?.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="form-group">
                            <label>User</label>
                            <select name="filterUser" class="form-control">
                                <option value="">All users</option>
                                @foreach (var u in Model.Users)
                                {
                                    <option value="@u" selected="@(Model.FilterUser == u)">@u</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Action</label>
                            <select name="filterAction" class="form-control">
                                <option value="">All actions</option>
                                @foreach (var a in Model.ActionTypes)
                                {
                                    <option value="@a" selected="@(Model.FilterAction == a)">@a</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Module / Entity</label>
                            <select name="filterEntity" class="form-control">
                                <option value="">All modules</option>
                                @foreach (var e in Model.EntityTypes)
                                {
                                    <option value="@e" selected="@(Model.FilterEntity == e)">@e</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Search</label>
                            <input type="text" name="searchText" class="form-control" value="@Model.SearchText" placeholder="Name, path, details…" />
                        </div>
                    </div>
                    <div style="margin-top:1rem; display:flex; gap:.5rem;">
                        <button type="submit" class="btn btn-primary">Search</button>
                        <a href="/AuditReport" class="btn btn-secondary">Reset</a>
                    </div>
                </form>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
                <h2>Audit Trail</h2>
                <span class="audit-meta">@Model.TotalRecords record(s)</span>
            </div>
            <div class="card-body table-responsive">
                <table class="data-table">
                    <thead class="grid-header">
                        <tr>
                            <th>Date / Time</th>
                            <th>User</th>
                            <th>Action</th>
                            <th>Module</th>
                            <th>Record</th>
                            <th>Page</th>
                            <th>IP</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Records.Count == 0)
                        {
                            <tr class="empty-row"><td colspan="8">No audit records found for the selected filters.</td></tr>
                        }
                        else
                        {
                            foreach (var row in Model.Records)
                            {
                                var actionClass = "action-" + row.ActionType.ToLowerInvariant();
                                <tr>
                                    <td>@row.ActionAt.ToString("dd-MMM-yyyy HH:mm:ss")</td>
                                    <td>@(string.IsNullOrEmpty(row.Username) ? "—" : row.Username)</td>
                                    <td><span class="action-pill @actionClass">@row.ActionType</span></td>
                                    <td>@row.EntityType</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(row.EntityName))
                                        {
                                            <strong>@row.EntityName</strong>
                                        }
                                        @if (row.EntityId.HasValue)
                                        {
                                            <span class="audit-meta"> #@row.EntityId</span>
                                        }
                                    </td>
                                    <td class="audit-meta">@row.PagePath</td>
                                    <td class="audit-meta">@(string.IsNullOrEmpty(row.IpAddress) ? "—" : row.IpAddress)</td>
                                    <td class="audit-details" title="@row.Details">@(string.IsNullOrEmpty(row.Details) ? "—" : row.Details)</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>

                @if (Model.TotalPages > 1)
                {
                    <div class="pager">
                        @if (Model.PageNumber > 1)
                        {
                            <a class="btn btn-secondary" href="@BuildPageUrl(Model.PageNumber - 1)">Previous</a>
                        }
                        <span class="audit-meta">Page @Model.PageNumber of @Model.TotalPages</span>
                        @if (Model.PageNumber < Model.TotalPages)
                        {
                            <a class="btn btn-secondary" href="@BuildPageUrl(Model.PageNumber + 1)">Next</a>
                        }
                    </div>
                }
            </div>
        </div>
    </main>

    @await Html.PartialAsync("_AppFooter")
</body>
</html>

@functions {
    string BuildPageUrl(int page)
    {
        var qs = new Dictionary<string, string?>
        {
            ["dateFrom"] = Model.DateFrom?.ToString("yyyy-MM-dd"),
            ["dateTo"] = Model.DateTo?.ToString("yyyy-MM-dd"),
            ["filterUser"] = Model.FilterUser,
            ["filterAction"] = Model.FilterAction,
            ["filterEntity"] = Model.FilterEntity,
            ["searchText"] = Model.SearchText,
            ["pageNumber"] = page.ToString()
        };
        var parts = qs.Where(kv => !string.IsNullOrWhiteSpace(kv.Value))
            .Select(kv => $"{kv.Key}={Uri.EscapeDataString(kv.Value!)}");
        return "/AuditReport?" + string.Join("&", parts);
    }
}
