@page
@model HRMS.Pages.UserSetupModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HRMS - @Model.PageTitle</title>
    <link rel="stylesheet" href="/css/style.css?v=5" />
</head>
<body>
    @await Html.PartialAsync("_AppHeader", Model.PageTitle)

    <main class="container">
        @if (!string.IsNullOrEmpty(Model.AlertMessage))
        {
            <div class="alert alert-@Model.AlertType">@Model.AlertMessage</div>
        }

        <div class="card">
            <div class="card-header">
                <h2>@(Model.Input.UserID > 0 ? "Edit User" : "Add New User")</h2>
            </div>
            <form method="post" action="/UserSetup?handler=Save">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" value="@Model.Input.UserID" />
                <div class="card-body">
                    <div class="form-grid">
                        <div class="form-group">
                            <label>User Code</label>
                            <input type="text" name="userCode" class="form-control"
                                   value="@Model.Input.UserCode" maxlength="20" readonly />
                        </div>
                        <div class="form-group">
                            <label>Username <span class="required">*</span></label>
                            <input type="text" name="username" class="form-control"
                                   value="@Model.Input.Username" maxlength="50"
                                   placeholder="Login username" />
                        </div>
                        <div class="form-group">
                            <label>Full Name <span class="required">*</span></label>
                            <input type="text" name="fullName" class="form-control"
                                   value="@Model.Input.FullName" maxlength="100" />
                        </div>
                        <div class="form-group">
                            <label>Email</label>
                            <input type="email" name="email" class="form-control"
                                   value="@Model.Input.Email" maxlength="100" />
                        </div>
                        <div class="form-group">
                            <label>@(Model.Input.UserID > 0 ? "New Password (leave blank to keep)" : "Password") <span class="required">@(Model.Input.UserID > 0 ? "" : "*")</span></label>
                            <input type="password" name="newPassword" class="form-control"
                                   autocomplete="new-password" />
                        </div>
                        <div class="form-group">
                            <label>Status</label>
                            <label class="checkbox-label">
                                <input type="checkbox" name="isActive" value="true"
                                       @(Model.Input.IsActive ? "checked" : "") /> Active
                            </label>
                        </div>
                        <div class="form-group">
                            <label>Administrator</label>
                            <label class="checkbox-label">
                                <input type="checkbox" name="isAdmin" value="true"
                                       @(Model.Input.IsAdmin ? "checked" : "") />
                                Admin (full access to all forms)
                            </label>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">
                        @(Model.Input.UserID > 0 ? "Update User" : "Save User")
                    </button>
                    <a href="/UserSetup" class="btn btn-secondary">Clear</a>
                </div>
            </form>
        </div>

        <div class="card mt-4">
            <div class="card-header"><h2>User List</h2></div>
            <div class="card-body table-responsive">
                <table class="data-table">
                    <thead class="grid-header">
                        <tr>
                            <th>Code</th>
                            <th>Username</th>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Users.Count == 0)
                        {
                            <tr class="empty-row"><td colspan="7">No users found.</td></tr>
                        }
                        else
                        {
                            foreach (var u in Model.Users)
                            {
                                <tr>
                                    <td>@u.UserCode</td>
                                    <td><strong>@u.Username</strong></td>
                                    <td>@u.FullName</td>
                                    <td>@u.Email</td>
                                    <td>
                                        @if (u.IsAdmin)
                                        {
                                            <span class="badge badge-warning">Administrator</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-info">User</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @(u.IsActive ? "badge-success" : "badge-danger")">
                                            @(u.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td class="actions-col" style="white-space:nowrap;">
                                        <a href="/UserRightsSetup?userId=@u.UserID"
                                           class="btn btn-secondary" style="padding:2px 10px;font-size:.8rem;">
                                            Manage Rights
                                        </a>
                                        <a class="btn-icon btn-edit" href="/UserSetup?editId=@u.UserID">Edit</a>
                                        <form method="post" action="/UserSetup?handler=Delete" style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="deleteId" value="@u.UserID" />
                                            <button type="submit" class="btn-icon btn-delete"
                                                    onclick="return confirm('Deactivate this user?')">X</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </main>
    @await Html.PartialAsync("_AppFooter")
</body>
</html>
