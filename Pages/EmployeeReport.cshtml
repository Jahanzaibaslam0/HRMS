@page
@model HRMS.Pages.EmployeeReportModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HRMS - @Model.PageTitle</title>
    <link rel="stylesheet" href="/css/style.css?v=5" />
    <style>
        #reportTable { font-size: .8rem; white-space: nowrap; }
        #reportTable th { position: sticky; top: 0; z-index: 1; }
        .report-toolbar { display: flex; flex-wrap: wrap; gap: .75rem; align-items: center; justify-content: space-between; }
        .report-toolbar .form-control { max-width: 320px; }
    </style>
</head>
<body>
    @await Html.PartialAsync("_AppHeader", Model.PageTitle)

    <main class="container">
        <div class="card">
            <div class="card-header space-between">
                <h2>Internal Employee Directory</h2>
                <div class="report-toolbar">
                    <form method="get" action="/EmployeeReport" style="display:flex;gap:.5rem;align-items:center;">
                        <input type="text" name="search" id="txtSearch" class="form-control"
                               value="@Model.Search" placeholder="Search employees…" />
                        <button type="submit" class="btn btn-secondary">Search</button>
                        @if (!string.IsNullOrEmpty(Model.Search))
                        {
                            <a href="/EmployeeReport" class="btn btn-secondary">Clear</a>
                        }
                    </form>
                    <a id="exportLink" href="/EmployeeReport?handler=DownloadExcel@(string.IsNullOrEmpty(Model.Search) ? "" : "&search=" + Uri.EscapeDataString(Model.Search))"
                       class="btn btn-primary">Export to Excel</a>
                </div>
            </div>
            <div class="card-body table-responsive" style="max-height:70vh;overflow:auto;">
                <table class="data-table" id="reportTable">
                    <thead class="grid-header">
                        <tr>
                            <th>Extension</th>
                            <th>Cell No</th>
                            <th>Email</th>
                            <th>Power BI ID</th>
                            <th>User ID</th>
                            <th>Title</th>
                            <th>Employee Code</th>
                            <th>Position Code</th>
                            <th>Position</th>
                            <th>Title Grade</th>
                            <th>Department</th>
                            <th>Division</th>
                            <th>Region</th>
                            <th>Team</th>
                            <th>Location</th>
                            <th>Sales Group</th>
                            <th>State</th>
                            <th>Based City</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Records.Count == 0)
                        {
                            <tr class="empty-row"><td colspan="18">No employee records found.</td></tr>
                        }
                        else
                        {
                            foreach (var row in Model.Records)
                            {
                                <tr>
                                    <td>@row.Extension</td>
                                    <td>@row.CellNo</td>
                                    <td>@row.Email</td>
                                    <td>@row.PowerID</td>
                                    <td>@row.UserID</td>
                                    <td>@row.Title</td>
                                    <td><code style="font-size:.75rem;background:#f1f5f9;padding:.1rem .4rem;border-radius:4px;">@row.EmployeeCode</code></td>
                                    <td>@row.PositionCode</td>
                                    <td>@row.Position</td>
                                    <td>@row.TitleGrade</td>
                                    <td>@row.Department</td>
                                    <td>@row.Division</td>
                                    <td>@row.Region</td>
                                    <td>@row.Team</td>
                                    <td>@row.Location</td>
                                    <td>@row.SalesGroup</td>
                                    <td>@row.State</td>
                                    <td>@row.BasedCity</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer" style="font-size:.85rem;color:#6b7280;">
                Showing @Model.Records.Count record(s)
                @if (!string.IsNullOrEmpty(Model.Search)) { <span>matching &ldquo;@Model.Search&rdquo;</span> }
            </div>
        </div>
    </main>

    @await Html.PartialAsync("_AppFooter")
    <script>
        (function () {
            var input = document.getElementById('txtSearch');
            var exportLink = document.getElementById('exportLink');
            if (!input || !exportLink) return;

            input.addEventListener('input', function () {
                var q = input.value.trim();
                exportLink.href = '/EmployeeReport?handler=DownloadExcel' +
                    (q ? '&search=' + encodeURIComponent(q) : '');
            });
        })();
    </script>
</body>
</html>
